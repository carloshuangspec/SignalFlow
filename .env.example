# AI_OS 环境变量配置
# 复制此文件为 .env 并填入真实值

# ─── API Keys ───
CLAUDE_API_KEY=sk-ant-xxx
DEEPSEEK_API_KEY=sk-xxx
GEMINI_API_KEY=AIza-xxx

# ─── Telegram Bot ───
TELEGRAM_BOT_TOKEN=123456:ABC-xxx
TELEGRAM_CHAT_ID=your_chat_id

# ─── 模型选择 ───
# 主力模型（摘要/分析）
PRIMARY_MODEL=claude-sonnet-4-6
# 批量模型（多帖初步筛选）
BATCH_MODEL=deepseek-chat
# 视觉模型（截图理解）
VISION_MODEL=gemini-2.5-flash

# ─── 爬虫配置 ───
# 每个平台每次抓取的最大帖子数
MAX_POSTS_PER_SOURCE=50
# 截图视口大小
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=900
# 请求间隔（秒），避免被限流
CRAWL_INTERVAL=3

# ─── 简报配置 ───
# 每日简报推送时间（北京时间）
MORNING_BRIEFING_HOUR=8
EVENING_BRIEFING_HOUR=20
# 紧急推送的最低重要度（1-10）
URGENT_THRESHOLD=8

# ─── 数据目录 ───
DATA_DIR=/data/ai_os
SCREENSHOTS_DIR=/data/ai_os/screenshots
KNOWLEDGE_DIR=/data/ai_os/knowledge
